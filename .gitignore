# Dependencies
node_modules/

# Environment & Secrets
.env
.env.local
.env.*.local
config.json

# Location-art staging (review images, auditions + ad-hoc); approved images ARE committed
docs/games/images/**/_review/
docs/games/images/**/_audition/
docs/games/images/**/_sandbox/
docs/games/images/_adhoc.png

# Ephemeral /go-to dev-skill save snapshots — regenerated & overwritten each invocation
docs/assets/*-go-to.snapshot.json

# Development
.claude/*
# ...but keep project skills under source control
!.claude/skills/
*.zip

# OS Files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE
.vscode/
.idea/
*.code-workspace
*.sublime-project
*.sublime-workspace

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Runtime
pids/
*.pid
*.seed
*.pid.lock

# Coverage & Testing
coverage/
.nyc_output/

# MCP / Tools
.mcp.json
eng.traineddata
screenshots/

# Windows artifacts
nul

# Backup files
*.backup
*.tar
*.bak

# Crash dumps and debug files
CrashReport.txt
Minidump.dmp
*.dmp

# SSL certificates and keys
*.pem
*.key
*.cert
*.crt
mkcert.exe

# Temporary files
*-temp.js
*-fix.txt
*-temp.md
ISSUES.md
tmpclaude-*-cwd

# Game files in root (not tracked - users download these)
/*.z3
/*.z4
/*.z5
/*.z6
/*.z7
/*.z8
/*.zblorb
/*.ulx
/*.gblorb
/dfrotz.exe
/frotz.exe

# But allow game files in games/ directory
!games/

# Documentation artifacts (not tracked)
/*.png
/*.jpg
/*.jpeg
/*.gif
/free-hosting-options.txt
/voice-error-notes.txt

# But allow documentation images in docs/ or reference/
!docs/**/*.png
!docs/**/*.jpg
!reference/**/*.png
!reference/**/*.jpg

# Scratch dir for headless-replay snapshots/probes
tmp/

# Blockout generated outputs (clay refs + styled renders) — throwaway
docs/games/images/*/_blockout/_gen/

# Blockout regenerable render outputs — clay captures + styled gen frames are
# recreated from the authored *.scene.json; keep the .scene.json + viewer .html.
# (Placed after the docs/**/*.png|jpg re-include rules above so these win.)
docs/games/images/*/_blockout/_clay/
docs/games/images/*/_blockout/*.png
docs/games/images/*/_blockout/*.jpg
docs/games/images/*/_blockout/*.jpeg

# Old icon backup (superseded set)
docs/icons-prev-promptL/
